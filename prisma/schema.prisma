generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Employee {
  id                    Int       @id @default(autoincrement())
  name                  String
  email                 String    @unique
  responsibilityScore   Int       @default(50)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  reasonLogs            ReasonLog[]
  escalations           Escalation[]

  @@map("employees")
}

model ReasonLog {
  id                    Int       @id @default(autoincrement())
  employeeId            Int
  reason                String
  description           String?
  reportedBy            String
  scoreImpact           Int       @default(-5)
  createdAt             DateTime  @default(now())

  employee              Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("reason_logs")
}

model SLARule {
  id                    Int       @id @default(autoincrement())
  scoreThreshold        Int       @default(40)
  daysThreshold         Int       @default(3)
  action                String    @default("alert")
  escalateToRole        String    @default("manager")
  active                Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("sla_rules")
}

model Escalation {
  id                    Int       @id @default(autoincrement())
  employeeId            Int
  ruleId                Int?
  reason                String
  escalatedBy           String    @default("system")
  status                String    @default("active")
  createdAt             DateTime  @default(now())
  resolvedAt            DateTime?

  employee              Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("escalations")
}